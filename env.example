# ============================================================================
# None Trainer - Environment Configuration
# ============================================================================
# Copy to .env and modify as needed:
#   Linux/Mac: cp env.example .env
#   Windows:   copy env.example .env
# ============================================================================

# ========================
# Service
# ========================
TRAINER_PORT=28000
TRAINER_HOST=0.0.0.0

# ========================
# Model Path
# ========================
MODEL_PATH=/datasets/studio/huggingface/models/Z-Image

# ========================
# Dataset
# ========================
DATASET_PATH=/home/waas/datasets

# ========================
# Ollama (image captioning)
# ========================
OLLAMA_HOST=http://127.0.0.1:11434

# ========================
# Training Output
# ========================
OUTPUT_PATH=/home/waas/model-output

# ========================
# Generation Output
# ========================
GENERATION_OUTPUT_PATH=/home/waas/image-output

# ========================
# Hardware (optional, auto-detect if empty)
# ========================
GPU_TIER=
GPU_MEMORY=

# ========================
# DINOv3 Model
# ========================
DINO_MODEL_PATH=./Dinov3-base

# ========================
# Debug
# ========================
DEBUG=0
